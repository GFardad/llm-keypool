      "limits": {
        "rpm": 30,
        "tpm": 6000,
        "rpd": 14400
      },
      "quota_reset": {
        "rpm_tpm": "rolling",
        "rpd": "daily_utc_midnight"
      },
      "quota_api": "headers",
