# LLM-APIPOOL Configuration
# Copy to .env and fill in your values

# Database path (default: ~/.llm-apipool/keys.db)
LLM_APIPOOL_DB=

# Encryption key for API key storage (auto-generated if empty)
LLM_APIPOOL_ENCRYPTION_KEY=

# Proxy API key (optional, for proxy auth)
LLM_APIPOOL_API_KEY=

# Rate limiting (requests/second, burst)
LLM_APIPOOL_RATE_LIMIT=10
LLM_APIPOOL_RATE_BURST=20

# Proxy bind address (default: 127.0.0.1)
LLM_APIPOOL_HOST=127.0.0.1

# Proxy port (default: 8000)
LLM_APIPOOL_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Force provider (optional, e.g., "groq")
LLM_APIPOOL_FORCE_PROVIDER=

# Force model (optional, e.g., "llama-3.3-70b-versatile")
LLM_APIPOOL_FORCE_MODEL=
